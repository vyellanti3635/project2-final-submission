extends ../layouts/main

block content
  .admin-contacts
    h1 Contact Submissions
    
    if contacts && contacts.length > 0
      .contacts-list
        each contact in contacts
          .contact-item(class=contact.isRead ? 'read' : 'unread')
            .contact-header
              .contact-info
                strong= contact.name
                span.contact-email  (#{contact.email})
                if contact.subject
                  span.contact-subject  - #{contact.subject}
              .contact-meta
                span.contact-date= new Date(contact.createdAt).toLocaleDateString() + ' ' + new Date(contact.createdAt).toLocaleTimeString()
                if !contact.isRead
                  span.badge-unread New
            
            .contact-message
              p= contact.message
            
            .contact-actions
              if !contact.isRead
                form.inline-form(method='POST', action=`/admin/contacts/${contact._id}/read?_method=PUT`)
                  button.btn.btn-small.btn-secondary(type='submit') Mark Read
              form.inline-form(method='POST', action=`/admin/contacts/${contact._id}?_method=DELETE`)
                button.btn.btn-small.btn-danger(type='submit', onclick='return confirm("Are you sure you want to delete this contact?")') Delete
    else
      .no-contacts
        p No contact submissions yet.
    
    .back-link
      a.btn.btn-secondary(href='/admin') Back to Dashboard
