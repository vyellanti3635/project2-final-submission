extends ../layouts/main

block content
  .admin-users
      h1 User Management
      
      if users && users.length > 0
        table.admin-table
          thead
            tr
              th Username
              th Email
              th Registration Date
          tbody
            each user in users
              tr
                td= user.username
                td= user.email
                td= user.createdAt.toLocaleDateString()
      else
        p.no-users No registered users found.
