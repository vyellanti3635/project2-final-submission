extends ../layouts/main

block content
  .admin-dashboard
    h1 Admin Dashboard
    .dashboard-actions
      h2 Quick Actions
      .action-buttons
        a.btn.btn-primary(href="/admin/posts/new") Create New Post
        a.btn.btn-secondary(href="/admin/comments") Moderate Comments
        a.btn.btn-secondary(href="/admin/contacts") View Contacts
        a.btn.btn-secondary(href="/admin/users") View Users
    
    .recent-posts
      h2 Manage Posts
      if recentPosts && recentPosts.length > 0
        table.admin-table
          thead
            tr
              th Title
              th Author
              th Views
              th Date
              th Actions
          tbody
            each post in recentPosts
              tr
                td
                  a(href=`/post/${post._id}`)= post.title
                td= post.author.username
                td= post.viewCount
                td= new Date(post.createdAt).toLocaleDateString()
                td.actions
                  a.btn-small(href=`/admin/posts/${post._id}/edit`) Edit
                  form.inline-form(action=`/admin/posts/${post._id}?_method=DELETE` method="POST")
                    button.btn-small.btn-danger(type="submit" onclick="return confirm('Are you sure you want to delete this post?')") Delete
      else
        p No posts yet.
