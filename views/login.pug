extends layouts/main

block content
  
  .auth-page
    .auth-container
      h1 Sign In
      
      form.auth-form(action="/login" method="POST")
        .form-group
          label(for="username") Username
          input#username(type="text" name="username" placeholder="username" required)
        
        .form-group
          label(for="password") Password
          input#password(type="password" name="password" placeholder="pasword" required)
        
        button.btn.btn-primary(type="submit") Sign In
        
      
      .auth-links
        p
          a(href="/register") Sign up here
